{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src", "cli", "tests", "*.config.*", "*.ts"],
  "exclude": ["dist", "out", "node_modules", ".astro"]
}
