---
import "../styles/globals.css";
import { url } from "../lib/url.ts";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  jsonLd?: unknown[];
}

const { title, description, canonical, jsonLd = [] } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const nav = [
  [url("/"), "Catalog"],
  [url("/compare"), "Compare"],
  [url("/wanted"), "Wanted"],
  [url("/observatory"), "Observatory"],
  [url("/learn"), "Learn"],
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="theme-color" content="#0b0d0f" />
    {jsonLd.map((obj) => <script is:inline type="application/ld+json" set:html={JSON.stringify(obj)} />)}
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ccircle cx='8' cy='8' r='6' fill='%2334d399'/%3E%3C/svg%3E"
    />
  </head>
  <body class="min-h-screen bg-page text-ink-body antialiased">
    <header class="sticky top-0 z-10 border-b border-rule bg-page/85 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-6 px-6 py-3">
        <a href={url("/")} class="flex items-baseline gap-2">
          <span class="inline-block h-2 w-2 rounded-sm bg-moss" style="box-shadow:0 0 8px var(--color-moss)"></span>
          <span class="font-serif text-xl text-ink">Terrarium</span>
          <span class="hidden font-mono text-[10px] uppercase tracking-[0.18em] text-ink-dim sm:inline">field guide</span>
        </a>
        <nav class="flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-[11px] uppercase tracking-[0.1em]">
          {nav.map(([href, label]) => (
            <a href={href} class="text-ink-muted hover:text-moss">{label}</a>
          ))}
        </nav>
      </div>
    </header>

    <slot />

    <footer class="mt-20 border-t border-rule">
      <div class="mx-auto max-w-5xl px-6 py-8 font-mono text-[11px] leading-relaxed text-ink-dim">
        Open registry · intake → certify → list. The measurement is the trust anchor — rebuild it yourself.
        <span class="text-ink-muted">Terrarium does not deploy or host CVMs.</span>
      </div>
    </footer>
  </body>
</html>
