---
import TierBadge from "./TierBadge.astro";
import ProofChip from "./ProofChip.astro";
import { CATEGORY_LABEL } from "../lib/catalog.ts";
import { url } from "../lib/url.ts";
import type { Integration } from "../../cli/src/schema/catalog.ts";

interface Props { i: Integration }
const { i } = Astro.props;
---

<li
  data-card
  data-category={i.category}
  data-tier={i.tier}
  data-proof={i.proofTier}
  data-fresh={i.freshness}
  class="tk-card group p-5"
>
  <a href={url(`/specimens/${i.id}`)} class="block">
    <div class="flex items-baseline justify-between gap-3">
      <span class="font-serif text-xl text-ink transition-colors group-hover:text-moss-deep">{i.commonName}</span>
      <TierBadge tier={i.tier} />
    </div>
    <div class="mt-1 font-mono text-xs text-ink-muted">
      {i.id} · <span class="text-ink-dim">{CATEGORY_LABEL[i.category] ?? i.category}</span>
    </div>
    <p class="mt-2 text-sm text-ink-body">{i.fieldGuide.description}</p>
    <div class="mt-3 flex items-center gap-3 font-mono text-[11px] text-ink-dim">
      <ProofChip proof={i.proofTier} />
      <span>· {i.freshness}</span>
      <span class="ml-auto text-ink-muted">{i.latestBuild.measurement.value.slice(0, 10)}…</span>
    </div>
  </a>
</li>
