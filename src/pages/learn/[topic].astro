---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { EXPLAINERS, getExplainer } from "../../lib/explainers.ts";
import { url } from "../../lib/url.ts";

export function getStaticPaths() {
  return EXPLAINERS.map((e) => ({ params: { topic: e.slug } }));
}

const { topic } = Astro.params;
const e = getExplainer(topic!)!;
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: new URL(url("/"), Astro.site).href },
    { "@type": "ListItem", position: 2, name: "Learn", item: new URL(url("/learn"), Astro.site).href },
    { "@type": "ListItem", position: 3, name: e.keyword },
  ],
};
---

<BaseLayout title={`${e.title} · Terrarium`} description={e.description} jsonLd={[breadcrumb]}>
  <main class="mx-auto max-w-3xl px-6 py-10">
    <nav aria-label="Breadcrumb" class="font-mono text-[11px] text-ink-dim">
      <a href={url("/")} class="hover:text-moss">Home</a> › <a href={url("/learn")} class="hover:text-moss">Learn</a> › <span class="text-ink-muted">{e.keyword}</span>
    </nav>
    <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.18em] text-moss">{e.keyword}</p>
    <h1 class="mt-2 font-serif text-4xl leading-tight text-ink">{e.title}</h1>
    <article class="mt-5 space-y-4 text-lg leading-relaxed text-ink-body">
      {e.body.map((p) => <p>{p}</p>)}
    </article>
    <p class="mt-8 font-mono text-[11px] text-ink-muted">
      ← <a href={url("/")} class="tk-link">Browse specimens</a> that put this into practice.
    </p>
  </main>
</BaseLayout>
