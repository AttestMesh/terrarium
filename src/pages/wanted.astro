---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readWanted } from "../../cli/src/io.ts";
import { url } from "../lib/url.ts";

// The demand ledger. In the open-repo model a request is a PR to wanted.yaml or a
// labelled GitHub issue; search-misses on the catalog become one-click requests.
const wanted = [...readWanted()].sort((a, b) => b.votes - a.votes);
const STATES = ["requested", "intent", "in-progress", "listed"] as const;
const STATE_LABEL: Record<string, string> = {
  requested: "Requested",
  intent: "Intent to package",
  "in-progress": "In progress",
  listed: "Listed",
};
const issueUrl = "https://github.com/AttestMesh/terrarium/issues/new?labels=wanted&title=Wanted:%20";
---

<BaseLayout
  title="Wanted — most-requested confidential CVM integrations · Terrarium"
  description="A demand ledger of confidential CVM integrations people want but that don't exist yet: request → intent → in-progress → listed, with upvotes. The build-prioritisation signal."
>
  <main class="mx-auto max-w-3xl px-6 py-10">
    <nav aria-label="Breadcrumb" class="font-mono text-[11px] text-ink-dim"><a href={url("/")} class="hover:text-moss">Home</a> › Wanted</nav>
    <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.18em] text-moss">demand ledger</p>
    <h1 class="mt-2 font-serif text-4xl text-ink">Wanted</h1>
    <p class="mt-2 max-w-2xl text-ink-body">
      Integrations people want that don't exist yet, ranked by demand.
      <a href={issueUrl} class="tk-link">Request a workload →</a>
    </p>

    {STATES.map((state) => {
      const items = wanted.filter((w) => w.state === state);
      return (
        <section class="mt-8">
          <h2 class="font-mono text-xs uppercase tracking-[0.16em] text-moss">{STATE_LABEL[state]} <span class="text-ink-dim">({items.length})</span></h2>
          <ul class="mt-3 space-y-2">
            {items.length === 0 && <li class="font-mono text-sm text-ink-dim">—</li>}
            {items.map((w) => (
              <li class="tk-card flex items-center justify-between gap-3 px-4 py-2.5">
                <span class="text-ink-body">
                  {w.workload}
                  {w.integrationId && (<> · <a href={url(`/specimens/${w.integrationId}`)} class="tk-link">view specimen</a></>)}
                </span>
                <span class="flex shrink-0 items-center gap-2 font-mono text-[11px] text-ink-dim">
                  <span class="tk-chip" style="--c:var(--color-moss)">▲ {w.votes}</span>
                  {w.origin}
                </span>
              </li>
            ))}
          </ul>
        </section>
      );
    })}
  </main>
</BaseLayout>
