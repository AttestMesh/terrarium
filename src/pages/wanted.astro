---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readWanted } from "../../cli/src/io.ts";

// The demand ledger. In the open-repo model a request is a PR to wanted.yaml or a
// labelled GitHub issue; search-misses on the catalog become one-click requests.
const wanted = [...readWanted()].sort((a, b) => b.votes - a.votes);
const STATES = ["requested", "intent", "in-progress", "listed"] as const;
const STATE_LABEL: Record<string, string> = {
  requested: "Requested",
  intent: "Intent to package",
  "in-progress": "In progress",
  listed: "Listed",
};
const issueUrl = "https://github.com/AttestMesh/terrarium/issues/new?labels=wanted&title=Wanted:%20";
---

<BaseLayout
  title="Wanted — most-requested confidential CVM integrations · Terrarium"
  description="A demand ledger of confidential CVM integrations people want but that don't exist yet: request → intent → in-progress → listed, with upvotes. The build-prioritisation signal."
>
  <main class="mx-auto max-w-3xl px-6 py-10">
    <nav aria-label="Breadcrumb" class="font-mono text-xs text-ink-muted"><a href="/" class="hover:text-moss-deep">Home</a> › Wanted</nav>
    <h1 class="mt-2 font-serif text-3xl text-moss-deep">Wanted</h1>
    <p class="mt-2 max-w-2xl text-ink-muted">
      Integrations people want that don't exist yet. White space ≠ demand, so every gap carries a number.
      <a href={issueUrl} class="text-moss-deep underline">Request a workload →</a>
    </p>

    {STATES.map((state) => {
      const items = wanted.filter((w) => w.state === state);
      return (
        <section class="mt-8">
          <h2 class="font-serif text-xl text-ink-body">{STATE_LABEL[state]} <span class="font-mono text-sm text-ink-muted">({items.length})</span></h2>
          <ul class="mt-3 space-y-2">
            {items.length === 0 && <li class="text-sm text-ink-muted">—</li>}
            {items.map((w) => (
              <li class="flex items-baseline justify-between rounded border border-rule bg-card px-4 py-2">
                <span>
                  {w.workload}
                  {w.integrationId && (<> · <a href={`/specimens/${w.integrationId}`} class="text-moss-deep underline">view specimen</a></>)}
                </span>
                <span class="font-mono text-xs text-ink-muted">▲ {w.votes} · {w.origin}</span>
              </li>
            ))}
          </ul>
        </section>
      );
    })}
  </main>
</BaseLayout>
