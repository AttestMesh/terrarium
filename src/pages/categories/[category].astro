---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SpecimenCard from "../../components/SpecimenCard.astro";
import { byCategory, CATEGORY_LABEL } from "../../lib/catalog.ts";

export function getStaticPaths() {
  return [...byCategory().keys()].map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
const members = byCategory().get(category!) ?? [];
const label = CATEGORY_LABEL[category!] ?? category!;
const description = `Confidential ${label.toLowerCase()} on Intel TDX: reproducible, measured CVM integrations with certified confidential boundaries, listed in Terrarium.`;
---

<BaseLayout title={`Confidential ${label} on Intel TDX · Terrarium`} description={description}>
  <main class="mx-auto max-w-5xl px-6 py-12">
    <nav aria-label="Breadcrumb" class="font-mono text-[11px] text-ink-dim">
      <a href="/" class="hover:text-moss">Home</a> › <span class="text-ink-muted">{label}</span>
    </nav>
    <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.18em] text-moss">category</p>
    <h1 class="mt-2 font-serif text-4xl text-ink">{label}</h1>
    <p class="mt-2 max-w-2xl text-ink-body">{description}</p>
    <ul class="mt-6 grid gap-3 sm:grid-cols-2">
      {members.map((i) => <SpecimenCard i={i} />)}
    </ul>
  </main>
</BaseLayout>
