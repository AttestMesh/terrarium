---
import BaseLayout from "../layouts/BaseLayout.astro";
import CatalogFilter from "../components/islands/CatalogFilter.svelte";
import SpecimenCard from "../components/SpecimenCard.astro";
import { allIntegrations } from "../lib/catalog.ts";
import { url } from "../lib/url.ts";

const integrations = allIntegrations();
const facets = {
  categories: [...new Set(integrations.map((i) => i.category))].sort(),
  tiers: [...new Set(integrations.map((i) => i.tier))].sort(),
  proofs: [...new Set(integrations.map((i) => i.proofTier))].sort(),
  freshness: [...new Set(integrations.map((i) => i.freshness))].sort(),
};
const guarded = integrations.filter((i) => i.tier === "guarded").length;
const title = "Terrarium — a field guide to confidential CVM integrations";
const description =
  "An open registry of guarded, reproducible, confidential CVM integrations. Each specimen reproduces to a verifiable measurement and ships a certified confidential boundary.";
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto max-w-5xl px-6 py-12">
    <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-moss">open registry · intake → certify → list</p>
    <h1 class="mt-3 max-w-3xl font-serif text-5xl leading-[1.05] text-ink">A field guide to confidential CVM integrations</h1>
    <p class="mt-4 max-w-2xl text-ink-body">
      Each specimen is an open-source workload packaged to draw the confidential boundary correctly — and a
      <strong class="text-ink">reproducible build whose measurement anyone can independently verify</strong>.
      Listing is permissionless; the value is the certification on top.
    </p>
    <div class="mt-5 flex flex-wrap gap-x-6 gap-y-1 font-mono text-[11px] text-ink-dim">
      <span><span class="text-moss">{guarded}</span> guarded</span>
      <span><span class="text-ink">{integrations.length}</span> listed</span>
      <span>measurement = dstack compose-hash · <a href={url("/learn/reproducible-builds")} class="tk-link">rebuild it yourself</a></span>
    </div>

    <div class="mt-8"><CatalogFilter client:load facets={facets} /></div>
    <p class="mt-3 font-mono text-[11px] text-ink-dim"><span id="filter-count">{integrations.length}</span> of {integrations.length} specimens</p>

    <ul class="mt-4 grid gap-3 sm:grid-cols-2">
      {integrations.map((i) => <SpecimenCard i={i} />)}
    </ul>
  </main>
</BaseLayout>
