---
import BaseLayout from "../layouts/BaseLayout.astro";
import { allIntegrations } from "../lib/catalog.ts";

// Compares all listed specimens side by side on their structured fields.
const integrations = allIntegrations();
const rows: { label: string; get: (i: (typeof integrations)[number]) => string }[] = [
  { label: "tier", get: (i) => i.tier },
  { label: "proof", get: (i) => i.proofTier },
  { label: "freshness", get: (i) => i.freshness },
  { label: "egress", get: (i) => i.latestBuild.boundarySpec.egress.policy },
  { label: "sealed volumes", get: (i) => String(i.latestBuild.boundarySpec.sealedVolumes.length) },
  { label: "RA-TLS surfaces", get: (i) => i.latestBuild.boundarySpec.raTlsSurfaces.join(", ") || "—" },
  { label: "signers", get: (i) => (i.attestations.length ? i.attestations.map((a) => a.reviewerId).join(", ") : "—") },
  { label: "measurement", get: (i) => i.latestBuild.measurement.value.slice(0, 12) + "…" },
];
---

<BaseLayout
  title="Compare confidential CVM integrations — boundary, tier, freshness · Terrarium"
  description="Side-by-side comparison of confidential CVM integrations on their structured fields: boundary spec, proof tier, certification tier, freshness, and measurement."
>
  <main class="mx-auto max-w-5xl px-6 py-10">
    <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-moss">comparison</p>
    <h1 class="mt-2 font-serif text-4xl text-ink">Compare specimens</h1>
    <p class="mt-2 text-ink-body">Boundary, proof, certification tier, freshness, and measurement, side by side.</p>
    <div class="tk-card mt-6 overflow-x-auto p-4">
      <table class="w-full border-collapse font-mono text-sm">
        <thead>
          <tr class="border-b border-rule">
            <th class="py-2 pr-4 text-left text-ink-dim">field</th>
            {integrations.map((i) => (
              <th class="py-2 pr-4 text-left"><a href={`/specimens/${i.id}`} class="tk-link">{i.id}</a></th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr class="border-b border-rule">
              <th class="py-2 pr-4 text-left text-ink-muted">{r.label}</th>
              {integrations.map((i) => <td class="py-2 pr-4 text-ink-body">{r.get(i)}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </main>
</BaseLayout>
